FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
RUN apk add --no-cache openssl chromium nss freetype harfbuzz ca-certificates ttf-freefont
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

WORKDIR /app

# Install dependencies
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY patches/ patches/
COPY packages/db/package.json packages/db/
COPY packages/api/package.json packages/api/
COPY packages/auth/package.json packages/auth/
COPY packages/social/package.json packages/social/
COPY packages/ai/package.json packages/ai/
COPY packages/queue/package.json packages/queue/
COPY packages/billing/package.json packages/billing/
COPY packages/logger/package.json packages/logger/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Generate Prisma client and build
# Placeholder env vars satisfy module-load-time validation (e.g., PrismaClient constructor,
# NextAuth provider init). Real values are injected at container runtime via docker-compose.
ENV DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/placeholder"
ENV NEXTAUTH_SECRET="build-time-placeholder"
ENV NEXTAUTH_URL="http://localhost:3000"
ENV SKIP_ENV_VALIDATION=1
RUN pnpm --filter @postautomation/db db:generate
RUN pnpm --filter @postautomation/web build

ENV NODE_ENV=production
EXPOSE 3000
ENV PORT=3000 HOSTNAME="0.0.0.0"
CMD ["pnpm", "--filter", "@postautomation/web", "start"]
