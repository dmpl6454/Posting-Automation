# ══════════════════════════════════════════════════════════════════
# PostAutomation — Production Environment Variables
# Copy to .env.production and fill in ALL values
# Domain: postautomation.co.in
# ══════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=postautomation
POSTGRES_PASSWORD=          # Generate: openssl rand -base64 32
POSTGRES_DB=postautomation

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=             # Generate: openssl rand -base64 32

# ─── NextAuth ────────────────────────────────────────────────────
NEXTAUTH_SECRET=            # Generate: openssl rand -base64 32
AUTH_SECRET=                # Same value as NEXTAUTH_SECRET (NextAuth v5 reads this)
APP_URL=https://postautomation.co.in
# NextAuth v5 — both keys must equal the canonical public URL
AUTH_URL=https://postautomation.co.in
NEXTAUTH_URL=https://postautomation.co.in
AUTH_TRUST_HOST=true

# ─── Auth Providers ──────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Social Platform OAuth ──────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Snapchat: OAuth app (kit.snapchat.com/manage), scope snapchat-profile-api.
# Connect works once set; posting/insights also need Public Profile API allowlisting.
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
# TikTok: paste the app's "Client Key" as TIKTOK_CLIENT_ID (OAuth + publish paths
# read ${PLATFORM}_CLIENT_ID). Legacy TIKTOK_CLIENT_KEY still accepted as a fallback.
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# ─── AI Providers ───────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ─── Stripe Billing ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Temporary: BILLING_DISABLED=true bypasses ALL plan/quota gates so every user
# (new and old) has free rein. Billing code stays intact — re-arm by setting
# this to false (or removing it) and redeploying. Unset = billing enforced.
BILLING_DISABLED=true

# ─── Object Storage (MinIO / S3) ────────────────────────────────
S3_ACCESS_KEY=              # Generate: openssl rand -hex 20
S3_SECRET_KEY=              # Generate: openssl rand -hex 40
S3_BUCKET=postautomation-media
S3_REGION=us-east-1

# ─── Sentry Error Tracking ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ─── Email (SMTP) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@postautomation.co.in

# ─── Backup ─────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30

# ─── Outreach (Brand Campaign Tracker) ─────────────────────────
RESEND_API_KEY=             # From resend.com dashboard
OUTREACH_FROM_EMAIL=biz@digitalsukoon.com
HUNTER_API_KEY=             # From hunter.io dashboard

# ─── Deployment ─────────────────────────────────────────────────
DEPLOY_SECRET=              # Generate: openssl rand -hex 32 — used to register deployments via API
