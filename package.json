{
  "name": "posting-automation",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:migrate": "pnpm --filter @postautomation/db db:migrate",
    "db:push": "pnpm --filter @postautomation/db db:push",
    "db:seed": "pnpm --filter @postautomation/db db:seed",
    "db:studio": "pnpm --filter @postautomation/db db:studio",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "turbo": "^2.8.16",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
