exports[`Repurpose render golden gate — default path is byte-identical (Phase 4 Task 10) > hook_bars cover render is unchanged 1`] = `
"<!DOCTYPE html><html><head><meta charset="utf-8"><style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{width:1080px;height:1350px;overflow:hidden;position:relative;font-family:'Inter',system-ui,sans-serif;background:#f7f7f8;}
.bg{position:absolute;inset:0;background:linear-gradient(135deg, #e11d48, #11131a);}
.logo{position:absolute;top:36px;left:40px;}
.bars{position:absolute;left:36px;right:36px;bottom:48px;display:flex;flex-direction:column;gap:14px;}
.bar{background:#fff;border-radius:10px;padding:18px 24px;box-shadow:0 6px 24px rgba(0,0,0,0.35);}
.hook{font-size:40px;font-weight:800;line-height:1.15;color:#111;}
.headline{font-size:44px;font-weight:800;line-height:1.12;color:#111;}
.headline .accent{color:#e11d48;}
</style></head><body>
<div class="bg"></div>
<div class="logo"><div style="width:56px;height:56px;border-radius:12px;background:#e11d48;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:24px;">A</div></div>

<div class="bars">
  
  <div class="bar"><div class="headline">Markets rally as central banks signal a pause on rate hikes</div></div>
</div>
</body></html>"
`;

