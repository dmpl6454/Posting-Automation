exports[`Repurpose render golden gate — default path is byte-identical (Phase 4 Task 10) > premium_editorial cover render is unchanged 1`] = `
"<!DOCTYPE html><html><head><meta charset="utf-8"><style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{width:1080px;height:1350px;overflow:hidden;position:relative;font-family:'Inter',system-ui,sans-serif;background:linear-gradient(135deg, #e11d48, #11131a);-webkit-font-smoothing:antialiased;}
.bg{position:absolute;inset:0;background:linear-gradient(135deg, #e11d48, #11131a);}
.scrim{position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%);}
.photo-scrim{position:absolute;left:0;right:0;bottom:0;height:62%;background:linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 40%, rgba(0,0,0,0) 100%);}
.logo{position:absolute;top:44px;left:48px;}
.block{position:absolute;left:56px;right:56px;bottom:96px;}
.label{font-style:italic;font-size:26px;font-weight:600;color:rgba(255,255,255,0.8);letter-spacing:0.01em;text-shadow:0 2px 22px rgba(0,0,0,0.55);}
.rule{width:64px;height:4px;background:#e11d48;border-radius:2px;margin:14px 0 22px;}
.headline{color:#ffffff;font-size:54px;font-weight:900;line-height:1.06;letter-spacing:-0.02em;word-break:break-word;text-shadow:0 2px 22px rgba(0,0,0,0.55);}
.handle{position:absolute;bottom:44px;left:56px;color:rgba(255,255,255,0.8);font-size:20px;font-weight:500;text-shadow:0 2px 22px rgba(0,0,0,0.55);}
</style></head><body>
<div class="bg"></div><div class="scrim"></div>
<div class="logo"><div style="width:64px;height:64px;border-radius:14px;background:#e11d48;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:27px;">A</div></div>
<div class="block">
  <div class="label">Acme Newsroom</div>
  <div class="rule"></div>
  <div class="headline">Markets rally as central banks signal a pause on rate hikes</div>
</div>
<div class="handle">@acmenews</div>
</body></html>"
`;

