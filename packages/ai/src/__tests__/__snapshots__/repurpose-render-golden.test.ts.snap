exports[`Repurpose render golden gate — default path is byte-identical (Phase 4 Task 10) > carousel body slide render is unchanged 1`] = `
"<!DOCTYPE html><html><head><meta charset="utf-8"><style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{width:1080px;height:1350px;overflow:hidden;position:relative;font-family:'Inter',system-ui,sans-serif;background:linear-gradient(135deg, #e11d48, #11131a);-webkit-font-smoothing:antialiased;}
.bg{position:absolute;inset:0;background:linear-gradient(135deg, #e11d48, #11131a);}
.scrim{position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%);}
.accent-band{position:absolute;top:0;left:0;width:14px;height:100%;background:#e11d48;}
.logo{position:absolute;top:44px;left:48px;}
.block{position:absolute;left:56px;right:56px;bottom:96px;}
.label{font-style:italic;font-size:26px;font-weight:600;color:rgba(255,255,255,0.8);letter-spacing:0.01em;}
.rule{width:64px;height:4px;background:#e11d48;border-radius:2px;margin:14px 0 22px;}
.subhead{color:#ffffff;font-size:40px;font-weight:800;line-height:1.1;letter-spacing:-0.02em;margin-bottom:22px;word-break:break-word;}
.body{color:#ffffff;font-size:46px;font-weight:600;line-height:1.28;letter-spacing:-0.01em;word-break:break-word;}
.cta{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 72px;text-align:center;}
.cta-rule{width:80px;height:5px;background:#e11d48;border-radius:3px;margin-bottom:32px;}
.cta-text{color:#ffffff;font-size:88px;font-weight:900;line-height:1.04;letter-spacing:-0.03em;word-break:break-word;}
.cta-sub{margin-top:24px;color:rgba(255,255,255,0.8);font-size:30px;font-weight:600;}
.handle{position:absolute;bottom:44px;left:56px;color:rgba(255,255,255,0.8);font-size:20px;font-weight:500;}
</style></head><body>
<div class="bg"></div><div class="scrim"></div>
<div class="accent-band"></div>
<div class="logo"><div style="width:64px;height:64px;border-radius:14px;background:#e11d48;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:27px;">A</div></div>
<div class="block">
    <div class="label">Acme Newsroom</div>
    <div class="rule"></div>
    <div class="subhead">Markets rally as central banks signal a pause on rate hikes</div>
    <div class="body">The decision follows three consecutive quarters of easing inflation and steadier employment figures across major economies.</div>
  </div>
<div class="handle">@acmenews</div>
</body></html>"
`;

